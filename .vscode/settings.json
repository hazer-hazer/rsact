{
  // "rust-analyzer.check.allTargets": false,
  "rust-analyzer.cargo.allTargets": true,
  "cSpell.words": [
    "colorspace",
    "Deque",
    "dirten",
    "downcasting",
    "Framebuf",
    "fullscreen",
    "pixelcolor",
    "Pixmap",
    "renderable",
    "rsact",
    "signum",
    "Skia",
    "Uninit",
    "vals",
    "viewports"
  ],
  "rust-analyzer.runnables.extraTestBinaryArgs": ["--test-threads=1"],
  "rust-analyzer.cargo.noDefaultFeatures": true,
  "rust-analyzer.cargo.features": [
    "single-thread",
    "debug-info",
    "simulator",
    "async",
    "tiny-skia",
    "embedded-graphics",
    "u8g2-fonts",
    "layout-diagnostics",
    "defmt"
  ],
  "rust-analyzer.check.noDefaultFeatures": true,
  "rust-analyzer.check.features": [
    "single-thread",
    "debug-info",
    "simulator",
    "tiny-skia"
    // "async"
  ],
  "rust-analyzer.testExplorer": true,
  "rust-analyzer.checkOnSave": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "rsact-icons/icon-libs": true
  }
}
